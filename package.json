{
  "name": "agent-one",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-first AI agent with a thin Node.js server.",
  "author": "Jan Tomasek",
  "main": "packaging/desktop/main.js",
  "scripts": {
    "start": "node A1.js serve",
    "dev": "node server/dev-server.js",
    "install:packaging": "npm install --prefix packaging",
    "desktop:dev": "node packaging/scripts/run-desktop-dev.js",
    "desktop:pack": "node packaging/scripts/package-host.js --dir",
    "desktop:dist": "node packaging/scripts/package-host.js",
    "desktop:dist:mac": "node packaging/scripts/package-macos.js",
    "package:desktop:host": "node packaging/scripts/package-host.js",
    "package:desktop:host:dir": "node packaging/scripts/package-host.js --dir",
    "package:desktop:macos": "node packaging/scripts/package-macos.js",
    "package:desktop:linux": "node packaging/scripts/package-linux.js",
    "package:desktop:windows": "node packaging/scripts/package-windows.js"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "com.agentone.desktop",
    "productName": "Agent One",
    "files": [
      "A1.js",
      "app/**/*",
      "commands/**/*",
      "server/**/*",
      "packaging/desktop/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "packaging/resources"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "entitlements": "packaging/platforms/macos/entitlements.mac.plist",
      "entitlementsInherit": "packaging/platforms/macos/entitlements.mac.plist"
    },
    "win": {
      "icon": "packaging/platforms/windows/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "packaging/platforms/linux/icons",
      "category": "Development",
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ]
    }
  },
  "nodejsformobile": {
    "entry": "A1.js",
    "defaultCommand": "serve",
    "purpose": "Thin mobile-compatible server bridge for fetch proxying and SQLite access."
  }
}
