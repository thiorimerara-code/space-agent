  "history": "../histories/partial_layout_fix_followup_requires_same_widget_repair.json",
  "expect": {
    "response_type": "thrust",
    "require_staging_line": true,
    "require_separator_line": true,
    "require_single_separator": true,
    "require_code_after_separator": true,
    "require_valid_javascript": true,
    "must_contain": [
      "_____javascript",
      "iphone-weather"
    ],
    "must_match_any": [
      {
        "pattern": "readWidget\\(\"iphone-weather\"\\)",
        "flags": "u"
      },
      {
        "pattern": "patchWidget\\(\"iphone-weather\"",
        "flags": "u"
      },
      {
        "pattern": "seeWidget\\(\"iphone-weather\"\\)",
        "flags": "u"
      }
    ],
    "must_not_match": [
      {
        "pattern": "^Done\\.$|^I see the grid issue|^The widget is|^Yes\\b",
        "flags": "imu"
      }
    ]
  }
}
