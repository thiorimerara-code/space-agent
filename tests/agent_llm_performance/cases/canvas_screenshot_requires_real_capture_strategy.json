{
  "id": "canvas_screenshot_requires_real_capture_strategy",
  "description": "canvas-based screenshot requests must use a real page-capture strategy, not a fabricated placeholder image with page title or url text",
  "history": "../histories/canvas_screenshot_requires_real_capture_strategy.json",
  "expect": {
    "response_type": "thrust",
    "require_staging_line": true,
    "require_separator_line": true,
    "require_single_separator": true,
    "require_code_after_separator": true,
    "require_valid_javascript": true,
    "must_contain": [
      "_____javascript"
    ],
    "must_match": [
      {
        "pattern": "(?:html2canvas|XMLSerializer|foreignObject|getDisplayMedia|ImageCapture|createImageBitmap\\(|drawImage\\()",
        "flags": "u"
      },
      {
        "pattern": "(?:Blob|createObjectURL|download|click\\(|showSaveFilePicker)",
        "flags": "u"
      }
    ],
    "must_not_match": [
      {
        "pattern": "simple DOM-to-canvas fallback|basic page capture|fillText\\(document\\.title|fillText\\(location\\.href|space\\.current\\.screenshot|screenshot helper|not available|I can['’]t|cannot",
        "flags": "iu"
      }
    ]
  }
}
