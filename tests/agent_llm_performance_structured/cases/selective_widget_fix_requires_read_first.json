{
  "id": "selective_widget_fix_requires_read_first",
  "description": "a selective widget repair request should read the widget first instead of patching blind",
  "history": "../histories/selective_widget_fix_requires_read_first.json",
  "expect": {
    "response_type": "thrust",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_contain": [
        "snake-game"
      ],
      "must_match": [
        {
          "pattern": "space\\.current\\.readWidget\\(",
          "flags": "u"
        }
      ],
      "must_not_match": [
        {
          "pattern": "space\\.current\\.patchWidget\\(",
          "flags": "u"
        }
      ]
    }
  }
}
