{
  "id": "space_navigation_after_user_push_uses_open_helper",
  "description": "after wrongly claiming the space cannot be opened, the agent should switch to the real open-space helper when the user pushes back",
  "history": "../histories/space_navigation_after_user_push_uses_open_helper.json",
  "expect": {
    "response_type": "thrust",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_contain": [
        "space-1"
      ],
      "must_not_contain": [
        "I can’t",
        "I can't"
      ],
      "must_match": [
        {
          "pattern": "openSpace\\(",
          "flags": "u"
        }
      ],
      "must_not_match": [
        {
          "pattern": "space\\.api\\.fileRead\\(",
          "flags": "u"
        }
      ]
    }
  }
}
