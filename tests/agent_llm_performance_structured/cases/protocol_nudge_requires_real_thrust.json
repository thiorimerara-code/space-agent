{
  "id": "protocol_nudge_requires_real_thrust",
  "description": "after staging-only hesitation and a user reminder about the execution gate, the next reply must be one real thrust response",
  "history": "../histories/protocol_nudge_requires_real_thrust.json",
  "expect": {
    "response_type": "thrust",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_contain": [
        "snake-game"
      ],
      "must_not_contain": [
        "I’m patching it now.",
        "I'm patching it now.",
        "Patching now."
      ],
      "must_match": [
        {
          "pattern": "space\\.current\\.patchWidget\\(",
          "flags": "u"
        }
      ],
      "must_not_match": [
        {
          "pattern": "^_+javascript\\s*$",
          "flags": "u"
        }
      ]
    }
  }
}
