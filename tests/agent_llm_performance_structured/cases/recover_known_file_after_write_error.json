{
  "id": "recover_known_file_after_write_error",
  "description": "after a known file write error, recovery should stay on the exact file target instead of broad discovery or fake success",
  "history": "../histories/recover_known_file_after_write_error.json",
  "expect": {
    "response_type": "thrust",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_contain": [
        "user.yaml"
      ],
      "must_match": [
        {
          "pattern": "space\\.api\\.(?:fileRead|fileWrite)\\(",
          "flags": "u"
        }
      ],
      "must_not_match": [
        {
          "pattern": "space\\.api\\.fileList\\(",
          "flags": "u"
        },
        {
          "pattern": "\\b(?:updated|fixed|written)\\b.*\\b(?:successfully|done)\\b",
          "flags": "iu"
        }
      ]
    }
  }
}
