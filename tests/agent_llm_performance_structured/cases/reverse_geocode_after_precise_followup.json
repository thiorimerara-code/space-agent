{
  "id": "reverse_geocode_after_precise_followup",
  "description": "after weather was fetched for known coordinates and the user asks where that is precisely, the agent should reverse geocode instead of answering vaguely",
  "history": "../histories/reverse_geocode_after_precise_followup.json",
  "expect": {
    "response_type": "thrust",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_contain": [
        "49.71985822231634",
        "17.221723412878973"
      ],
      "must_not_contain": [
        "Likely in the",
        "near the",
        "approximately"
      ],
      "must_match": [
        {
          "pattern": "reverse|nominatim|display_name|address|geocode",
          "flags": "iu"
        }
      ]
    }
  }
}
