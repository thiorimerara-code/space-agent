{
  "id": "space_navigation_after_take_me_there_uses_open_helper",
  "description": "after the user says take me there, the agent should call the open-space helper instead of rereading metadata",
  "history": "../histories/space_navigation_after_take_me_there_uses_open_helper.json",
  "expect": {
    "response_type": "thrust",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_contain": [
        "space-1"
      ],
      "must_match": [
        {
          "pattern": "openSpace\\(",
          "flags": "u"
        }
      ],
      "must_not_match": [
        {
          "pattern": "space\\.api\\.fileRead\\(",
          "flags": "u"
        }
      ]
    }
  }
}
