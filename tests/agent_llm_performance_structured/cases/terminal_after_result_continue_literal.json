{
  "id": "terminal_after_result_continue_literal",
  "description": "a tool result that literally says continue should be treated as result data, not as an instruction to continue executing",
  "history": "../histories/terminal_after_result_continue_literal.json",
  "expect": {
    "response_type": "terminal",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_match": [
        {
          "pattern": "\\S",
          "flags": "u"
        }
      ]
    }
  }
}
