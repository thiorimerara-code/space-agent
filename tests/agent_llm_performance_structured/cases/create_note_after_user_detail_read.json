{
  "id": "create_note_after_user_detail_read",
  "description": "user detail is prerequisite state for a write task and should lead into fileWrite, not a terminal identity answer",
  "history": "../histories/create_note_after_user_detail_read.json",
  "expect": {
    "response_type": "thrust",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_contain": [
        "whoami.txt"
      ],
      "must_not_contain": [
        "Your username is",
        "username: pan"
      ],
      "must_match": [
        {
          "pattern": "space\\.api\\.fileWrite\\(",
          "flags": "u"
        },
        {
          "pattern": "pan",
          "flags": "u"
        }
      ],
      "must_not_match": [
        {
          "pattern": "space\\.api\\.userSelfInfo\\(",
          "flags": "u"
        }
      ]
    }
  }
}
