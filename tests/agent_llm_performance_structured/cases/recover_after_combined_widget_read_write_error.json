{
  "id": "recover_after_combined_widget_read_write_error",
  "description": "after framework rejects a combined widget read-and-patch turn, recovery should be a pure read turn",
  "history": "../histories/recover_after_combined_widget_read_write_error.json",
  "expect": {
    "response_type": "thrust",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_contain": [
        "snake-game"
      ],
      "must_not_contain": [
        "patched successfully",
        "done"
      ],
      "must_match": [
        {
          "pattern": "space\\.current\\.readWidget\\(",
          "flags": "u"
        }
      ],
      "must_not_match": [
        {
          "pattern": "space\\.current\\.patchWidget\\(",
          "flags": "u"
        }
      ]
    }
  }
}
