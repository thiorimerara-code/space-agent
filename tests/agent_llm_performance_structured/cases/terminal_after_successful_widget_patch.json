{
  "id": "terminal_after_successful_widget_patch",
  "description": "after a successful patch that satisfies the request, the agent should stop executing and answer once",
  "history": "../histories/terminal_after_successful_widget_patch.json",
  "expect": {
    "response_type": "terminal",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_not_contain": [
        "live snake source",
        "source is ready",
        "ready for"
      ],
      "must_not_match": [
        {
          "pattern": "^(?:Patching|Loading|Reading|Fetching|Updating)\\b",
          "flags": "imu"
        }
      ]
    }
  }
}
