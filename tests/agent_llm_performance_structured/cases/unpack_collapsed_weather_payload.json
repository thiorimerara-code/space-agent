{
  "id": "unpack_collapsed_weather_payload",
  "description": "collapsed payloads should trigger another extraction attempt instead of a stop or offer",
  "history": "../histories/unpack_collapsed_weather_payload.json",
  "expect": {
    "response_type": "thrust",
    "message": {
