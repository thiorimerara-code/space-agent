{
  "id": "finish_weather_after_geolocation",
  "description": "geolocation coordinates are prerequisite data, not the final answer when the user asked for weather",
  "history": "../histories/finish_weather_after_geolocation.json",
  "expect": {
    "response_type": "thrust",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_not_contain": [
        "Your location is approximately",
        "Likely in the",
        "approximately 49.",
        "near the"
      ],
      "must_match": [
        {
          "pattern": "(?:open-meteo|wttr\\.in)",
          "flags": "u"
        }
      ]
    }
  }
}
