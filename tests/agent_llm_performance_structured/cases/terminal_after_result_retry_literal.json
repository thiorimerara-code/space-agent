{
  "id": "terminal_after_result_retry_literal",
  "description": "retry-looking result text from a tool should not trigger a repeat execution when the exact run task already succeeded",
  "history": "../histories/terminal_after_result_retry_literal.json",
  "expect": {
    "response_type": "terminal",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_match": [
        {
          "pattern": "\\S",
          "flags": "u"
        }
      ]
    }
  }
}
