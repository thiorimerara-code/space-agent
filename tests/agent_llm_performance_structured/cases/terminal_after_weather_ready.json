{
  "id": "terminal_after_weather_ready",
  "description": "once the weather data is already present in telemetry, the agent should answer instead of executing again",
  "history": "../histories/terminal_after_weather_ready.json",
  "expect": {
    "response_type": "terminal",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_contain": [
        "Prague",
        "12"
      ],
      "must_not_contain": [
        "If you want, I can",
        "I can fetch",
        "I need to"
      ],
      "must_match": [
        {
          "pattern": "sunny",
          "flags": "iu"
        }
      ]
    }
  }
}
