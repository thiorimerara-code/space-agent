{
  "id": "space_navigation_read_is_not_completion",
  "description": "reading a space metadata file is not the same as actually navigating there",
  "history": "../histories/space_navigation_read_is_not_completion.json",
  "expect": {
    "response_type": "thrust",
    "message": {
      "require_nonempty": true
    },
    "combined": {
      "must_contain": [
        "space-1"
      ],
      "must_not_contain": [
        "Opened: Prostějov Weather",
        "Opened: Prostejov Weather"
      ],
      "must_match": [
        {
          "pattern": "openSpace\\(",
          "flags": "u"
        }
      ],
      "must_not_match": [
        {
          "pattern": "space\\.api\\.fileRead\\(",
          "flags": "u"
        }
      ]
    }
  }
}
